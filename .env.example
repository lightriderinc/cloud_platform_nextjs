# IQM Resonance API token, used server-side by the /api/iqm proxy route.
# Get a token from IQM Resonance and copy this file to .env.local (gitignored).
# Never commit the real token.
IQM_TOKEN=

# Rigetti QCS API token (OPTIONAL). The calibration endpoints work without
# auth; set this only if you need authenticated access.
RIGETTI_TOKEN=

# IBM Quantum (Qiskit Runtime REST API), used server-side by the /api/ibm proxy.
# The proxy exchanges this API key for a short-lived IAM token automatically,
# so only the API key and instance CRN are needed. Never commit real values.
IBM_CLOUD_API_KEY=
IBM_INSTANCE_CRN=
# Optional. IBM-API-Version header (defaults to a known-good date) and region
# base URL (use https://eu-de.quantum.cloud.ibm.com for the eu-de region).
IBM_API_VERSION=
IBM_QUANTUM_BASE_URL=

# --- EMS (light-rider-platform/ems-egress) ---
# Base URL of the EMS egress service (no trailing slash), e.g.
# https://ems.lightriderinc.com or http://localhost:7081 for local dev.
# Required — /api/ems/entropy returns 500 if unset.
EMS_BASE_URL=

# Server-only key sent as `x-ems-api-key` and `Authorization: Bearer` on every
# EMS entropy call. EMS's real auth is Bearer-token entitlement resolution
# (ems-egress/src/entitlement.rs, verified against ems-admin) — an anonymous
# call is downgraded to the Free grant, which can't draw from anything but
# pool_fastest and never gets multi_source. Set this to a key provisioned
# with full entitlements so every signed-in cloud-platform user gets every
# currently-available source. `x-ems-api-key` itself is inert until EMS grows
# a route that reads it — never commit the real value.
EMS_API_KEY=

# --- Billing (Stripe) ---
# Local dev database for billing state (customers, subscriptions, credit
# ledger). Swap to a postgresql:// URL for staging/production.
DATABASE_URL="file:./dev.db"

# From the Stripe Dashboard (Developers -> API keys). Use test-mode keys
# until Tony/Jake confirm live-mode is ready.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# locally, or the Dashboard's webhook endpoint config in staging/prod.
STRIPE_WEBHOOK_SECRET=

# Price IDs for User Pricing plans (Products -> Prices in Stripe Dashboard).
STRIPE_PRICE_USER_STARTER=
STRIPE_PRICE_USER_DEVELOPER=
STRIPE_PRICE_USER_PROFESSIONAL=

# Price IDs for API Pricing plans.
STRIPE_PRICE_API_STARTER=
STRIPE_PRICE_API_DEVELOPER=
STRIPE_PRICE_API_BUSINESS=

# Event name configured on the Stripe Billing Meter used for EaaS API
# overage (Dashboard -> Billing -> Meters). Must match exactly.
STRIPE_METER_EVENT_NAME=

# --- Stripe -> Logto validation flow ---
# Stripe Price ID for the throwaway "validation" subscription used to
# exercise the checkout -> webhook -> Logto role-assignment pipeline
# end-to-end without touching the real pricing tiers.
STRIPE_PRICE_VALIDATION_TEST=

# Logto Management API machine-to-machine app credentials (Logto Console ->
# Applications -> create a Machine-to-Machine app, then grant it access to
# the Management API resource). Server-only — never expose to the client.
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# Logto role id granted to a user once their validation subscription goes
# active/trialing (Logto Console -> Roles -> copy the role's id).
LOGTO_PRO_ROLE_ID=

